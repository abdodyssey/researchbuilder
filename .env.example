# ── Required ─────────────────────────────────────────────────────────────────
SECRET_KEY=generate-random-64-char-string-here
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://researchbuilder:your_db_password@localhost:5432/researchbuilder

# SQLite (local dev only)
# DATABASE_URL=sqlite:///data/researchbuilder.db

# ── App Settings ─────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
OUTPUT_DIR=./output
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Vercel Frontend (set in Vercel dashboard) ────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
